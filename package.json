{
  "name": "trace",
  "version": "0.1.0",
  "private": true,
  "description": "A collaboration-first desktop IDE for macOS.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -s first \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "package:mac:unsigned": "npm run build && electron-builder --mac --dir --publish never -c.mac.identity=null -c.mac.notarize=false",
    "dist:mac:unsigned": "npm run build && electron-builder --mac --publish never -c.mac.identity=null -c.mac.notarize=false",
    "release:mac:arm64": "node scripts/check-mac-release-env.cjs && npm run build && electron-builder --mac --arm64 --publish never -c.mac.forceCodeSigning=true",
    "release:mac:x64": "node scripts/check-mac-release-env.cjs && npm run build && electron-builder --mac --x64 --publish never -c.mac.forceCodeSigning=true",
    "rebuild:native": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run --exclude electron/account.test.cjs && node --test electron/account.test.cjs",
    "typecheck": "tsc -b --pretty false",
    "start": "electron ."
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "latest",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "latest",
    "monaco-editor": "^0.55.1",
    "motion": "^12.42.2",
    "node-pty": "^1.1.0",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "latest",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "^4.1.10",
    "wait-on": "latest"
  },
  "overrides": {
    "dompurify": "3.4.12"
  },
  "build": {
    "appId": "com.trace.desktop",
    "productName": "Trace",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "npmRebuild": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/**/*.test.cjs",
      "!**/*.map"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": true,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "${productName} ${version}",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
